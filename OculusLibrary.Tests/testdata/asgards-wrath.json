{"label":"MDCAppStoreV2ParityAppPDPInfo_app$defer$MDCAppStoreV2ParityAppPDPReviews_app","path":["app_store_item"],"data":{"display_name":"Asgard's Wrath","quality_rating_score":4.4596912521441,"platform":"PC","viewer_entitlement":{"__typename":"EntitlementInfo","__isEntitlementItem":"EntitlementInfo","active_state":"PERMANENT","grant_reason":"ADDITIONAL_ENTITLEMENT_GRANT","grant_time":1700415349,"expiration_time":0,"is_active":true,"item":{"__typename":"Application","id":"1180401875303371","display_name":"Asgard's Wrath","canonical_name":"sanzaru-games-inc-wrath","latest_supported_binary":{"__typename":"PCBinary","id":"6551935964816575"}},"id":"1562026557195421:1180401875303371"},"id":"1180401875303371","support_website_url":null,"can_viewer_review":true,"quality_ratings_by_viewer":[],"quality_rating_count":3498,"quality_rating_i18n_score_string":"4.5","quality_rating_i18n_count_string":"3.4K","quality_review_count":null,"quality_rating_histogram_aggregate_all":[{"star_rating":1,"count":225},{"star_rating":2,"count":98},{"star_rating":3,"count":147},{"star_rating":4,"count":402},{"star_rating":5,"count":2626}],"user_reviews2":{"edges":[{"node":{"id":"34680611838196588","author":{"id":"993348330683038","alias":"TENCUHTLI","name":null,"smallIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39001656_6448975001786983_9094238751843550296_n.webp?stp=c0.0.304.304a_dst-webp_s32x32&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E9CT2f5Yy-MQ7kNvwG8yfp_&_nc_oc=AdquL1CbJWR3jU5GfxP-uEcgePfvvtStNxN0mhatBGBcxn5Jph8cAyDZxqTBjncGLMg&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfyACWH_woHSpkKy4uas-4KCiDI3BD5WHcQzX4-JD0Ko-w&oe=69D07858"},"mobileIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39001656_6448975001786983_9094238751843550296_n.webp?stp=c0.0.304.304a_dst-webp_s48x48&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E9CT2f5Yy-MQ7kNvwG8yfp_&_nc_oc=AdquL1CbJWR3jU5GfxP-uEcgePfvvtStNxN0mhatBGBcxn5Jph8cAyDZxqTBjncGLMg&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afw4q66K84Lry7Z8yWXpubPXa5Jz2aShGVlBt5AhRkTRAg&oe=69D07858"},"tabletIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39001656_6448975001786983_9094238751843550296_n.webp?stp=c0.0.304.304a_dst-webp_s64x64&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E9CT2f5Yy-MQ7kNvwG8yfp_&_nc_oc=AdquL1CbJWR3jU5GfxP-uEcgePfvvtStNxN0mhatBGBcxn5Jph8cAyDZxqTBjncGLMg&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfzOUvjVuKsZ42hdDD0yGnXn1oe-esQSqDmabpICyFYVXQ&oe=69D07858"}},"is_early_access_review":false,"score":5,"review_description":"If you are looking for the ultimate VR adventure, Asgard\u2019s Wrath (and its incredible sequel) is a game you cannot miss. After reading many reviews, it is clear that this title sets a completely new standard for what a virtual reality game can be.\n\nWhat makes this game truly special is its attention to \"the little things.\" Most games give you a sword and a mission, but Asgard\u2019s Wrath gives you a living world. For example, the environmental interactions are amazing. You can take a torch, set a spider web on fire, and then use that same flame to light up other materials or torches in a dark dungeon. These tiny details make you feel like you are actually there, rather than just playing a character.\n\nMany people were excited for the game Behemoth, but honestly, it is not even close to this masterpiece. While other games might have big bosses, they often feel empty or repetitive. Asgard\u2019s Wrath combines:\n\u2022 Epic Scale: You can switch between a human-sized hero and a massive \"God form.\"\n\u2022 Deep Combat: The sword-fighting and parrying feel smooth and realistic.\n\u2022 Rich Story: It offers over 60 hours of gameplay, which is rare for VR.\n\nThis isn't just a \"good VR game\"it is a high quality RPG that competes with the best \"flat\" games on PC or console. The puzzles are clever, the world of Norse and Egyptian mythology is beautiful, and the physics-based interactions are the best in the industry.","review_title":"If you are looking for the ultimate VR","date":1772708533,"translated_review_title":null,"translated_review_description":null,"translated_developer_response_body":null,"developer_response":null,"review_helpful_count":4,"review_rank_by_viewer":null,"reported_by_viewer":false,"__typename":"QualityRating"},"cursor":"AQHSuzOejtBQPHmniztifueI_WWauLx0_JpI4MY5O8HaYwWEvk8bubX9AugcTGPtPNV2MSqjyiCjKGNca4_VPymREg"},{"node":{"id":"2018654718995071","author":{"id":"106611696866059","alias":"JaySolaire","name":null,"smallIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/12482172_106612203532675_6040694458977091584_n.webp?stp=c0.0.304.304a_dst-webp_s32x32&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i5_6W4L_BFYQ7kNvwHjmyTI&_nc_oc=Adp3vbGRcfVqWY4DwRmKD3fFIJLrA16_lxp9M5pyZfcqPa_hY3JSJM-kMDQHCLn6d3A&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afw93dVceEzX4kc1qIzqGV1yKMSelAJWngQ_o0mBaBs4XA&oe=69D059C6"},"mobileIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/12482172_106612203532675_6040694458977091584_n.webp?stp=c0.0.304.304a_dst-webp_s48x48&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i5_6W4L_BFYQ7kNvwHjmyTI&_nc_oc=Adp3vbGRcfVqWY4DwRmKD3fFIJLrA16_lxp9M5pyZfcqPa_hY3JSJM-kMDQHCLn6d3A&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afxp0JBhnydJpIsRb7Z_YCAVisbgcHaEox-5_bpOmAlBtg&oe=69D059C6"},"tabletIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/12482172_106612203532675_6040694458977091584_n.webp?stp=c0.0.304.304a_dst-webp_s64x64&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i5_6W4L_BFYQ7kNvwHjmyTI&_nc_oc=Adp3vbGRcfVqWY4DwRmKD3fFIJLrA16_lxp9M5pyZfcqPa_hY3JSJM-kMDQHCLn6d3A&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afzsbyq492zIa8BrIb_nkMI5SlhcOpDmiSMpu-ArlJZSog&oe=69D059C6"}},"is_early_access_review":false,"score":3,"review_description":"This game has it all- great graphics, great world, incredible detail. Only problem? It also has a gigantic marker over every character's head that says \"Click me!\" The immersion and story of this game is ruined by the fact that every movement is spoon fed into you in gigantic slobbering bites. I wouldn't mind if the markers were smaller, or if they could be disabled, but you have no option to play this game except on babylevel intelligence quest difficulty.","review_title":"YELLOW PAINT EVERYWHERE, NO IMMERSION","date":1773182136,"translated_review_title":null,"translated_review_description":null,"translated_developer_response_body":null,"developer_response":null,"review_helpful_count":2,"review_rank_by_viewer":null,"reported_by_viewer":false,"__typename":"QualityRating"},"cursor":"AQHSbMnqqou94Om_5QW9x82vQAxax1mpRmGKIbpVLR4vWs0uU84PjRJnY7Bf-287Ip_BqqG58zpbZRnDoKhCbxDW6w"},{"node":{"id":"1337746098035450","author":{"id":"102802624863143","alias":"PackedCupid","name":null,"smallIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031321_104028004740605_7162355526388532549_n.webp?stp=c0.0.304.304a_dst-webp_s32x32&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpMqyggW2VAQ7kNvwEi0-6S&_nc_oc=AdrBk005JBODoJZcbIYqoFtk6341hec2OtP2tVf2o8sxdV5FTWaTjAJ-tdCR0eSxXF4&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfzEaaXc_HDgjdjTbnG4WGtC098lEhMKz0G8BV2o5ifrRA&oe=69D06751"},"mobileIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031321_104028004740605_7162355526388532549_n.webp?stp=c0.0.304.304a_dst-webp_s48x48&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpMqyggW2VAQ7kNvwEi0-6S&_nc_oc=AdrBk005JBODoJZcbIYqoFtk6341hec2OtP2tVf2o8sxdV5FTWaTjAJ-tdCR0eSxXF4&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afw0L-x65Fk2ZHbDHr-jIiqXecAp_lkIATZ4AEwt1EWesg&oe=69D06751"},"tabletIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031321_104028004740605_7162355526388532549_n.webp?stp=c0.0.304.304a_dst-webp_s64x64&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpMqyggW2VAQ7kNvwEi0-6S&_nc_oc=AdrBk005JBODoJZcbIYqoFtk6341hec2OtP2tVf2o8sxdV5FTWaTjAJ-tdCR0eSxXF4&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfyVrr-irtNWtapFFDSy0bqvCb8_7SRNcxVnrofAzjd1Zw&oe=69D06751"}},"is_early_access_review":false,"score":5,"review_description":"I got my Rift S back in 2020, and for some reason I never got to Asgard's Wrath. It was always on my list, but time got away from me. 5 years later, I'm on a Quest 3 and finally decided to give this game a shot, and I am so glad I did.\n\nI'm about 15 hours in and Asgard's Wrath is quickly becoming one of my favorite VR games of all time. Visually, it still holds up today and looks especially good compared to many VR games being released now which are usually targeting standalone headsets. It also runs well on my mid-high range RTX 4070 \/ 5800X3D combo.\n\nThe gameplay has a learning curve (playing on the highest difficulty), but I've since become much better at parrying and I am now hooked on the combat. Level design is fun and puzzles are interesting. It really is a joy to walk around a world of Norse mythology so beautifully realized. Also, there is TONS of side content apart from the already lengthy main quest, which I'm only about a fourth of the way through.\n\nYou also get an anthology-like set of stories across different characters that you grow to care about while playing, which ultimately supplement the overarching plot. I'm still uncovering a lot, but I enjoy the way these stories unravel, and I like how I am still impacted by them even if they are not the main focus of the game.\n\nFinally, the music is also a treat to listen to and I have many of the various themes playing in my head at any given time during the day. I am constantly excited thinking about the next time I can boot this game up. Please, give this game a go -- it is well worth the $40 price tag, which is more value rich than 99\u0025 of games (VR or flatscreeen) coming out today.","review_title":"Underappreciated Gem","date":1767196810,"translated_review_title":null,"translated_review_description":null,"translated_developer_response_body":null,"developer_response":null,"review_helpful_count":14,"review_rank_by_viewer":null,"reported_by_viewer":false,"__typename":"QualityRating"},"cursor":"AQHSauh3N8J-1DBNSrimrGM5kn4b-kHOKNHMYgKx9ZoFeFjTktiLRDdKtnvVCWZ7DrlvwJv_ZfFFoA3Wd0oHKmwhlw"},{"node":{"id":"25594032803600325","author":{"id":"808144435949172","alias":"Dopple324","name":null,"smallIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031650_7304772806286270_5692660405140002125_n.webp?stp=c0.0.956.956a_dst-webp_s32x32&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFPktYDZ2RMQ7kNvwGmZCNZ&_nc_oc=Adq8H_BvWc0Xv2-HT_Xf-gxYXA6TMYCPiqjlepsJqfedjZr7mE6ue8dZN2B5krvR92I&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfzBSzxd1ZHNzckDooSunTZzHv9nNtPdiOn_1v33y4tzfA&oe=69D068E0"},"mobileIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031650_7304772806286270_5692660405140002125_n.webp?stp=c0.0.956.956a_dst-webp_s48x48&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFPktYDZ2RMQ7kNvwGmZCNZ&_nc_oc=Adq8H_BvWc0Xv2-HT_Xf-gxYXA6TMYCPiqjlepsJqfedjZr7mE6ue8dZN2B5krvR92I&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_AfwsuAyl0MtKK5gOGJvW5vlrJbAikJBun0QNoVxCMbNeMA&oe=69D068E0"},"tabletIcon":{"uri":"https:\/\/scontent.oculuscdn.com\/v\/t64.5771-25\/39031650_7304772806286270_5692660405140002125_n.webp?stp=c0.0.956.956a_dst-webp_s64x64&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFPktYDZ2RMQ7kNvwGmZCNZ&_nc_oc=Adq8H_BvWc0Xv2-HT_Xf-gxYXA6TMYCPiqjlepsJqfedjZr7mE6ue8dZN2B5krvR92I&_nc_zt=3&_nc_ht=scontent.oculuscdn.com&_nc_ss=7a3a8&oh=00_Afy3dQ0AHPE-5j7KccuSYYWkLSURtG92xTGIJ4XCogS1dA&oe=69D068E0"}},"is_early_access_review":false,"score":5,"review_description":"Definitely one of the best VR games among HL: Alyx and Lone Echo; it\u00b4s a great game. There\u00b4s nothing more to say.","review_title":"One of the Best and a must-play","date":1769665184,"translated_review_title":null,"translated_review_description":null,"translated_developer_response_body":null,"developer_respo