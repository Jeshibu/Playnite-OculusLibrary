{"data":{"app_store_item":{"__typename":"Application","addons_including":{"count":0},"__isAppStoreItem":"Application","is_ccve_pdp_warning_enforced":false,"is_cg_pdp_warning_enforced":false,"is_platform_abuse_pdp_warning_enforced":false,"is_dmca_pdp_warning_enforced":false,"is_vrc_pdp_warning_enforced":false,"is_vrc_compliant":true,"display_long_description":"Sprint Vector is officially in the VR League! Race your way to victory and grab Sprint Vector on sale now. Register now to compete!\n\nSprint Vector is the ultimate competitive VR game: a multiplayer parkour racing game that merges the physical thrill of athletic competition with the unhinged energy of a crazy game show. Survios\u2019 innovative Fluid Locomotion System allows players to comfortably run, jump, climb, and fly at extreme speeds.\n\nHigh-Octane Single and Multiplayer Racing: Compete against up to eight contestants live before the entire galaxy, or train hard for the title on hazardous solo challenge maps.\n\nActive VR Gameplay: Use your entire body to run, jump, drift, zip, climb, fling, shoot, dodge, and fly with intuitive motion controls.\n\nWeapons and Items: What\u2019s a little friendly competition without a bit of self-serving sabotage? Take aim at both the course and your competitors with glove blasts and game-changing power-ups.\n\nChoose Your Racer: From space kids and disc jockeys, to graffiti artists and gangster sharks, enjoy a diverse cast of playable characters from every corner of the galaxy.","long_description_uses_markdown":false,"display_machine_translated_long_description":"Sprint Vector is officially in the VR League! Race your way to victory and grab Sprint Vector on sale now. Register now to compete!\n\nSprint Vector is the ultimate competitive VR game: a multiplayer parkour racing game that merges the physical thrill of athletic competition with the unhinged energy of a crazy game show. Survios\u2019 innovative Fluid Locomotion System allows players to comfortably run, jump, climb, and fly at extreme speeds.\n\nHigh-Octane Single and Multiplayer Racing: Compete against up to eight contestants live before the entire galaxy, or train hard for the title on hazardous solo challenge maps.\n\nActive VR Gameplay: Use your entire body to run, jump, drift, zip, climb, fling, shoot, dodge, and fly with intuitive motion controls.\n\nWeapons and Items: What\u2019s a little friendly competition without a bit of self-serving sabotage? Take aim at both the course and your competitors with glove blasts and game-changing power-ups.\n\nChoose Your Racer: From space kids and disc jockeys, to graffiti artists and gangster sharks, enjoy a diverse cast of playable characters from every corner of the galaxy.","long_description_requires_machine_translation":false,"id":"1425858557493354","is_viewer_duc_admin":false,"organization":{"id":"1032224993515763"}},"viewer":{}},"extensions":{"server_metadata":{"request_start_time_ms":1773697973022,"time_at_flush_ms":1773697974215},"is_final":false}}
